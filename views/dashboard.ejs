<!DOCTYPE html>
<html>
<head>
    <title>Dashboard | PlacementPro</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
</head>

<body style="
    margin:0;
    background:#000;
    color:#fff;
    font-family:'Inter', sans-serif;
    display:flex;
    flex-direction:column;
    min-height:100vh;
">

    <!-- NAVBAR -->
    <div style="
        display:flex;
        justify-content:space-between;
        align-items:center;
        padding:20px 60px;
        border-bottom:1px solid #111;
    ">
        <h2 style="margin:0; font-weight:600;">PlacementPro</h2>

        <div>
            <span style="margin-right:20px; color:#aaa;">
                Welcome, <%= user.username %>
            </span>

            <a href="/auth/logout" style="
                text-decoration:none;
                padding:8px 18px;
                border-radius:20px;
                border:1px solid #333;
                color:#fff;
                font-size:14px;
            "
            onmouseover="this.style.border='1px solid #fff'"
            onmouseout="this.style.border='1px solid #333'">
                Logout
            </a>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div style="
        flex:1;
        padding:60px;
    ">

        <h1 style="font-weight:600; margin-bottom:10px;">
            Your Dashboard
        </h1>

        <p style="color:#777; margin-bottom:40px;">
            Track applications. Monitor interviews. Stay consistent.
        </p>

        <!-- CARDS -->
        <div style="
            display:grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap:30px;
        ">

            <!-- Applications Card -->
            <div style="
                background:#0a0a0a;
                padding:30px;
                border-radius:15px;
                border:1px solid #111;
            ">
                <h3 style="margin-top:0;">Applications</h3>
                <p style="color:#888;">
                    Manage all your company applications here.
                </p>
                <a href="/documents" style="color:#fff; text-decoration:none;">View →</a>
            </div>

            <!-- Resume Tools -->
            <div style="
                background:#0a0a0a;
                padding:30px;
                border-radius:15px;
                border:1px solid #111;
            ">
                <h3 style="margin-top:0;">Resume Optimizer</h3>
                <p style="color:#888;">
                    Improve ATS score and optimize resume.
                </p>
                <a href="/documents/ATS" style="color:#fff; text-decoration:none;">Open →</a>
            </div>

            <!-- Documents -->
            <div style="
                background:#0a0a0a;
                padding:30px;
                border-radius:15px;
                border:1px solid #111;
            ">
                <h3 style="margin-top:0;">Documents</h3>
                <p style="color:#888;">
                    Access your saved academic & placement documents.
                </p>
                <a href="/documents" style="color:#fff; text-decoration:none;">Access →</a>
            </div>

        </div>

    </div>

    <!-- FOOTER -->
    <div style="
        padding:20px;
        text-align:center;
        border-top:1px solid #111;
        color:#555;
        font-size:13px;
    ">
        © <%= new Date().getFullYear() %> PlacementPro. Built for smarter placements.
    </div>

</body>
</html>